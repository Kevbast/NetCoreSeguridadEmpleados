
@using System.Security.Claims

<h1>PERFIL DEL EMPLEADO @Context.User.Identity.Name</h1>

<ul class="list-group">
    <li class="list-group-item">
        <h2 style="color:blueviolet">Oficio: @Context.User.FindFirst(ClaimTypes.Role).Value</h2>
    </li>
    <li class="list-group-item">
        <h2 style="color:darkorange">Salario: @Context.User.FindFirst("Salario")</h2>
    </li>
    <li class="list-group-item">
        <h2 style="color:darkred">Departamentos: @Context.User.FindFirst("Departamento")</h2>
    </li>
</ul>

<h4>TODOS LOS CLAIMS DEL USUARIO</h4>
<ul class="list-group">
    @foreach(Claim claim in Context.User.Claims)
    {
        <li class="list-group-item">@claim.Type: <b>@claim.Value</b></li>
    }
</ul>

